# =============================================================================
# Faktur Developer Platform — environment variables
# =============================================================================
# Production values. For local development, copy this file to `.env` and
# replace each value with its localhost equivalent (or pull the committed
# `apps/platform/.env` which already targets localhost).
# =============================================================================


# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Base URL of the Faktur backend. Every request from the platform (OAuth flow,
# /auth/me, /team/all, /dashboard/settings/api-keys/*) hits this URL.
NEXT_PUBLIC_API_BASE_URL=https://api.fakturapp.cc/api/v1


# -----------------------------------------------------------------------------
# OAuth (Faktur Developer Platform app)
# -----------------------------------------------------------------------------
# client_id of the entry registered in the oauth_apps table for this platform.
NEXT_PUBLIC_OAUTH_CLIENT_ID=faktur-developer-platform

# Redirect URI declared in the OAuth app's redirect_uris[]. Must match exactly
# (scheme + host + path).
NEXT_PUBLIC_OAUTH_REDIRECT_URI=https://platform.fakturapp.cc/oauth/callback

# Scopes requested at /oauth/authorize, space-separated.
NEXT_PUBLIC_OAUTH_SCOPES=profile offline_access


# -----------------------------------------------------------------------------
# Sibling apps (header links + OpenGraph metadataBase)
# -----------------------------------------------------------------------------
# Public URL of THIS platform (Next.js metadataBase for OG images, etc.).
NEXT_PUBLIC_PLATFORM_URL=https://platform.fakturapp.cc

# Main Faktur web app — "App Faktur" link in the platform header.
NEXT_PUBLIC_DASHBOARD_URL=https://fakturapp.cc

# Developer portal — "Documentation" link in the platform header.
NEXT_PUBLIC_DOCS_URL=https://developers.fakturapp.cc


# -----------------------------------------------------------------------------
# OAuth webhook receiver (this app receives events from the backend)
# -----------------------------------------------------------------------------
# Public URL of the webhook endpoint exposed by THIS platform. Paste this
# value into the OAuth app's "webhook_url" field via the dashboard admin so
# the backend dispatches token.issued / token.refreshed / token.revoked /
# authorization.granted events here.
NEXT_PUBLIC_OAUTH_WEBHOOK_URL=https://platform.fakturapp.cc/api/webhooks/oauth

# Shared secret used to verify the X-Faktur-Signature HMAC. Must match the
# whsec_... value stored on the OAuth app server-side. Server-only — DO NOT
# prefix with NEXT_PUBLIC_.
OAUTH_WEBHOOK_SECRET=whsec_replace_with_value_from_oauth_app_creation
