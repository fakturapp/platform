# Faktur Developer Platform — environment variables

# Backend API base URL — toutes les requêtes
NEXT_PUBLIC_API_BASE_URL=https://localhost:3333/api/v1

# OAuth
NEXT_PUBLIC_OAUTH_CLIENT_ID=0a6b8bf4602d2420750cb85a15ca8de4

# Redirect URI déclarée dans la liste redirect_uris de l'app OAuth
NEXT_PUBLIC_OAUTH_REDIRECT_URI=https://platform.fakturapp.cc/oauth/callback

# Scopes demandés au moment de l'autorisation
NEXT_PUBLIC_OAUTH_SCOPES=team.read api_keys.manage

# URL de l'app Faktur principale
# Local : http://localhost:3000
# Prod  : https://fakturapp.cc
NEXT_PUBLIC_DASHBOARD_URL=https://fakturapp.cc

# URL du portail développeur
NEXT_PUBLIC_DOCS_URL=https://developers.fakturapp.cc
