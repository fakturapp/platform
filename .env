# Faktur Developer Platform — environment variables

# Backend API base URL — toutes les requêtes (auth + clés API + webhooks) sortent ici
# Local : http://localhost:3333/api/v1
# Prod  : https://api.fakturapp.cc/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333/api/v1

# OAuth — client_id de l'app "Faktur Developer Platform" enregistrée dans oauth_apps
NEXT_PUBLIC_OAUTH_CLIENT_ID=faktur-developer-platform

# Redirect URI déclarée dans la liste redirect_uris de l'app OAuth
# Local : http://localhost:3002/oauth/callback
# Prod  : https://platform.fakturapp.cc/oauth/callback
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3002/oauth/callback

# Scopes demandés au moment de l'autorisation (séparés par espace)
NEXT_PUBLIC_OAUTH_SCOPES=team.read api_keys.manage

# URL de l'app Faktur principale (lien "App Faktur" dans le header)
# Local : http://localhost:3000
# Prod  : https://fakturapp.cc
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# URL du portail développeur (lien "Documentation" dans le header)
# Local : http://localhost:3001
# Prod  : https://developers.fakturapp.cc
NEXT_PUBLIC_DOCS_URL=http://localhost:3001
